# ── FIT-OCR environment variables ───────────────────────────────────────────
# Copy this file to .env and adjust values.
#   cp .env.example .env

# ── Server ──────────────────────────────────────────────────────────────────
FIT_OCR_PORT=8001
NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443          # uncomment for HTTPS
# CERT_DIR=./nginx/certs        # TLS cert directory

# ── OCR Engine ──────────────────────────────────────────────────────────────
DEVICE=cpu                      # cpu | cuda
ENABLE_TABLE=false              # enable table structure recognition (slow)
CLOUD_MODEL=glm-4v-plus         # glm-4v-plus | glm-4v-flash

# ── ZhipuAI Cloud API (required for cloud/fallback engines) ─────────────────
ZHIPUAI_API_KEY=

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
